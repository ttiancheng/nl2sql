{
  "table_name": "zzvc_device_basic_bom",
  "table_comment": "产品选型 BOM 表,定义产品选型设备的 BOM/配件明细。",
  "fields": [
    {
      "field_name": "id",
      "data_type": "int(30)",
      "nullable": false,
      "default": null,
      "comment": null
    },
    {
      "field_name": "bom_name",
      "data_type": "varchar(30)",
      "nullable": false,
      "default": null,
      "comment": "设备名称"
    },
    {
      "field_name": "bom_model",
      "data_type": "varchar(30)",
      "nullable": true,
      "default": null,
      "comment": "设备型号"
    },
    {
      "field_name": "bom_brand",
      "data_type": "varchar(30)",
      "nullable": true,
      "default": null,
      "comment": "品牌信息"
    },
    {
      "field_name": "bom_factory",
      "data_type": "varchar(30)",
      "nullable": true,
      "default": null,
      "comment": "生产厂家"
    },
    {
      "field_name": "bom_config_num",
      "data_type": "varchar(10)",
      "nullable": true,
      "default": null,
      "comment": "配置数量"
    },
    {
      "field_name": "bom_packing_num",
      "data_type": "varchar(30)",
      "nullable": true,
      "default": null,
