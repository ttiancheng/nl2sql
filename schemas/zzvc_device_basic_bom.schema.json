    {
      "field_name": "bom_packing_weight",
      "data_type": "varchar(30)",
      "nullable": true,
      "default": null,
      "comment": "BOM 包装重量"
    },
    {
      "field_name": "bom_specification_manual",
      "data_type": "text",
      "nullable": true,
      "default": null,
      "comment": "BOM 产品规格书"
    },
    {
      "field_name": "bom_operation_manual",
      "data_type": "text",
      "nullable": true,
      "default": null,
      "comment": "BOM 操作指导书"
    },
    {
      "field_name": "bom_remark",
      "data_type": "varchar(200)",
      "nullable": true,
      "default": null,
      "comment": "BOM 备注"
    },
    {
      "field_name": "cId",
      "data_type": "int(30)",
      "nullable": true,
      "default": null,
      "comment": "设备表对应id"
