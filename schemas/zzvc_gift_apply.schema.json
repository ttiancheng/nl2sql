      "data_type": "int(30)",
      "nullable": false,
      "default": null,
      "comment": null
    },
    {
      "field_name": "user_id",
      "data_type": "int(30)",
      "nullable": false,
      "default": null,
      "comment": "销售人员id"
    },
    {
      "field_name": "review_date",
      "data_type": "int(50)",
      "nullable": false,
      "default": null,
